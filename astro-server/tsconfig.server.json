{
  "extends": "./tsconfig.json",
  "include": ["src/server.ts"],
  "exclude": ["dist", "dist-runtime"],
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist-runtime",
    "noEmit": false,
    "target": "ES2022",
    "lib": ["ES2022"],
    "verbatimModuleSyntax": true
  }
}
